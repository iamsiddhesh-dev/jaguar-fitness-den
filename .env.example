# Web3Forms access key (free tier) — create at https://web3forms.com and paste the key here.
# Contact form degrades to "coming soon" messaging when this is unset.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# GA4 measurement ID (e.g. G-XXXXXXXXXX) from the GA4 property's Data Streams settings.
# GA4 script (and all tracking calls) is a no-op when this is unset.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
